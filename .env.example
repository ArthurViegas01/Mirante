# ============================================================
# Mirante — exemplo de configuração. Copie para .env e preencha.
# NENHUM segredo real é versionado. Tudo vem do ambiente.
# ============================================================

# ---- Aplicação ----
APP_ENV=development            # development | production
HTTP_ADDR=:8080                # endereço de escuta da API
# Origem do frontend permitida no CORS (exata, sem curinga em produção).
WEB_ORIGIN=http://localhost:5173

# ---- Banco (libSQL/Turso ou SQLite local) ----
# file: -> arquivo local (dev, pure-Go, sem dependência externa)
# libsql://HOST  ou  http://HOST:PORT -> servidor libSQL/sqld/Turso (produção)
DATABASE_URL=file:./data/mirante.db
# Ex. Turso hospedado:
#   DATABASE_URL=libsql://meu-banco-org.turso.io
#   DATABASE_AUTH_TOKEN=<token gerado com `turso db tokens create`>
# Token de autenticação do Turso (apenas para libsql:// remoto).
DATABASE_AUTH_TOKEN=

# ---- Sessão / Auth ----
SESSION_COOKIE_NAME=mirante_session
SESSION_TTL=720h               # validade absoluta da sessão (ex.: 30 dias)
# Owner único. OPCIONAL: se OWNER_EMAIL estiver vazio, a instância sobe sem dono
# e o **primeiro acesso (signup) na própria UI** cria a conta do dono (depois o
# cadastro fecha). Preencher abaixo semeia o dono no boot (atalho de dev). Use
# OWNER_PASSWORD (texto, só no bootstrap) OU OWNER_PASSWORD_HASH (Argon2id, prod).
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=troque-este-segredo
OWNER_PASSWORD_HASH=

# Chave-mestra (KEK) para cifrar segredos em repouso (AEAD), base64 de 32 bytes.
# Gere com: openssl rand -base64 32
APP_SECRET_KEY=

# ---- Recuperação de senha (e-mail) ----
# A tela "Esqueci minha senha" envia um link por e-mail. Ordem de escolha do
# transporte: Resend (API HTTP) → SMTP → nenhum (o link sai só no log da API).
#
# RECOMENDADO — Resend (https://resend.com): API HTTP, free tier de 3k/mês.
# Verifique um domínio seu no painel e envie de um endereço dele (MAIL_FROM). Sem
# domínio, use onboarding@resend.dev (só entrega no SEU e-mail, modo teste).
RESEND_API_KEY=
# Remetente (domínio verificado no Resend; ou onboarding@resend.dev p/ teste).
# Vale tanto para Resend quanto para SMTP.
MAIL_FROM=Mirante <no-reply@seudominio.com>

# ALTERNATIVA — SMTP. No docker-compose, sem nada aqui o padrão é o Mailpit (caixa
# local, http://localhost:8025). Suporta STARTTLS (587) e TLS implícito (465).
# Gmail (atalho p/ teste; precisa de "Senha de app" de 16 chars, com 2FA):
#   SMTP_HOST=smtp.gmail.com / SMTP_PORT=587 / SMTP_USERNAME=voce@gmail.com
#   SMTP_PASSWORD=<senha de app> / MAIL_FROM=Mirante <voce@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Validade do link de redefinição (duração Go: 1h, 30m, …).
PASSWORD_RESET_TTL=1h

# ---- LLM (F3: aderência de vaga, geração de CV/carta) ----
LLM_PROVIDER=groq              # groq (default, implementado) | anthropic | openai
LLM_MODEL=                     # vazio = default do provider (groq: llama-3.3-70b-versatile)
# A key é lida de LLM_API_KEY (genérica) OU da convencional do provider abaixo.
# Sem key, a API sobe normalmente e as features de LLM ficam indisponíveis.
LLM_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Limite de chamadas LLM por rota por minuto.
LLM_RATE_PER_MINUTE=20

# ---- Monitor (F4: rollups/pruning do histórico de checks) ----
# Dias de retenção dos checks brutos (1 linha/check). Mais antigos que isso são
# agregados em rollups horários e os brutos são podados (a cada hora). >= 1.
MONITOR_RETENTION_DAYS=14

# Webhook de alerta (F5, opcional): a cada transição de serviço (up/degraded/down)
# a API faz POST JSON nesta URL (http/https). Vazio = só alerta in-app (sino).
ALERT_WEBHOOK_URL=

# ---- Observabilidade (OpenTelemetry) ----
# Com endpoint setado, a API exporta traces via OTLP/HTTP (um span por request,
# propagação W3C). Vazio = provider no-op (sem overhead). Ex.: http://collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mirante-api
